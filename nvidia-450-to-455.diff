+++ NVIDIA-Linux-x86_64-455.23.04/kernel/common/inc/nv-time.h	2020-09-14 02:28:16.000000000 +0200
@@ -24,29 +24,220 @@
 #define __NV_TIME_H__
 
 #include "conftest.h"
-
+#include <linux/sched.h>
+#include <linux/delay.h>
+#include <linux/interrupt.h>
 #include <linux/ktime.h>
 
-#if defined (NV_TIMEVAL_PRESENT)
-typedef struct timeval nv_timeval; 
-#else
-typedef struct __kernel_old_timeval nv_timeval;
-#endif
