 {
     bool allocated_dev = false;
@@ -1073,6 +1122,8 @@ static void uvm_exit(void)
 
     unregister_chrdev_region(g_uvm_base_dev, NVIDIA_UVM_NUM_MINOR_DEVICES);
 
+    uvm_test_unload_state_exit();
+
     pr_info("Unloaded the UVM driver.\n");
 }
 
